WITH all_orders AS (SELECT ord.ID AS ORDER_ID,
      COUNT(*) AS NUM_RESULTS,
      Sum(CASE
        WHEN To_Char(tr.VERIFIED_DT, 'HH24:MI') < '12:00' THEN 1
        ELSE 0
      END) AS NUM_BEFORE_645,
      Sum(CASE
        WHEN To_Char(tr.VERIFIED_DT, 'HH24:MI') < '07:30' THEN 1
        ELSE 0
      END) AS NUM_BEFORE_730,
      Sum(CASE
        WHEN To_Char(tr.VERIFIED_DT, 'HH24:MI') < '09:00' THEN 1
        ELSE 0
      END) AS NUM_BEFORE_900
    FROM V_P_LAB_MISCEL_INFO misc
      INNER JOIN V_P_LAB_STAY st ON st.BILLING = misc.OWNER_ID
      INNER JOIN V_P_LAB_PATIENT pt ON st.PATIENT_AA_ID = pt.AA_ID
      INNER JOIN V_P_LAB_ORDER ord ON ord.STAY_AA_ID = st.AA_ID
      INNER JOIN V_P_LAB_TEST_RESULT tr ON tr.ORDER_AA_ID = ord.AA_ID
      INNER JOIN V_P_LAB_ORDERED_TEST otst ON otst.ORDER_AA_ID = ord.AA_ID
      LEFT JOIN V_P_BB_Result bbr ON bbr.ORDERNO = otst.ORDER_NO
      INNER JOIN V_P_LAB_TUBE tb ON tb.ORDER_AA_ID = ord.AA_ID
      INNER JOIN V_P_LAB_SPECIMEN sp ON sp.AA_ID = tb.SPECIMEN_AA_ID AND tr.SPECIMEN_TYPE = tb.TUBE_TYPE
    WHERE misc.SUB_ID = 'Exp Disch' AND misc.VALUE IS NOT NULL AND
      misc.VALUE BETWEEN :Date1 AND :Date2 AND ord.COLLECT_CENTER_ID = 'T1' AND
      sp.DRAW_TYPE = 'V' AND ord.ORDERING_TECH_ID LIKE 'HIS' AND
      ord.COLLECT_TIME = 0400 AND
      ord.COLLECT_DATE BETWEEN To_Date(:Date1, 'YYYYMMDD') AND To_Date(:Date2, 'YYYYMMDD') AND
      otst.ORDERING_DT BETWEEN To_Date(:Date1, 'YYYYMMDD') AND
      To_Date(Concat(:Date2, '2359'), 'YYYYMMDDHH24MI')
    GROUP BY ord.ID),
  compliant_orders AS (SELECT all_orders.ORDER_ID,
      CASE
        WHEN all_orders.NUM_RESULTS = all_orders.NUM_BEFORE_645 THEN 1
        ELSE 0
      END AS IS_COMPLIANT,
      CASE
        WHEN all_orders.NUM_RESULTS = all_orders.NUM_BEFORE_730 THEN 1
        ELSE 0
      END AS IS_COMPLIANT_730,
      CASE
        WHEN all_orders.NUM_RESULTS = all_orders.NUM_BEFORE_900 THEN 1
        ELSE 0
      END AS IS_COMPLIANT_900
    FROM all_orders),
  compliance_summary AS (SELECT COUNT(*) AS TOTAL_ORDERS,
      Sum(compliant_orders.IS_COMPLIANT) AS TOTAL_COMPLIANT,
      Round(Sum(compliant_orders.IS_COMPLIANT) * 100.0 / NullIf(COUNT(*), 0),
      2) AS COMPLIANCE_PERCENTAGE,
      Sum(compliant_orders.IS_COMPLIANT_730) AS TOTAL_COMPLIANT_730,
      Round(Sum(compliant_orders.IS_COMPLIANT_730) * 100.0 / NullIf(COUNT(*),
      0), 2) AS COMPLIANCE_PERCENTAGE_730,
      Sum(compliant_orders.IS_COMPLIANT_900) AS TOTAL_COMPLIANT_900,
      Round(Sum(compliant_orders.IS_COMPLIANT_900) * 100.0 / NullIf(COUNT(*),
      0), 2) AS COMPLIANCE_PERCENTAGE_900
    FROM compliant_orders)
SELECT ord.STAY_AA_ID,
  Concat(Concat(pt.LAST_NAME, ','), pt.FIRST_NAME) AS PT_NAME,
  misc.VALUE AS EDD,
  misc.SUB_ID,
  CASE
    WHEN misc.VALUE IS NOT NULL THEN 1
    ELSE 0
  END AS VALUE_NOT_NULL,
  To_Char(misc.ADD_DT, 'YYYYMMDD') AS "DATE",
  misc.ADD_TECH,
  pt.ID AS MRN,
  st.CLINIC_ID AS WARD,
  st.ROOM AS ROOM,
  st.BED AS BED,
  ord.ID AS ORD_ID,
  ord.COLLECT_CENTER_ID AS DEPOT,
  ord.ORDERED_DT AS ORD_DT,
  otst.COLLECTED_TECH AS COL_TECH1,
  Max(tr.COLLECT_DT) AS COLL_DT1,
  Max(tr.RECEIVE_DT) AS REC_DT,
  Max(tr.VERIFIED_DT) AS VER_DT,
  To_Char(ord.ORDERED_DT, 'YYYYMMDD') AS ORD_DATE,
  To_Char(otst.ORDERING_DT, 'YYYYMMDD') AS ORDERING_DATE,
  misc.OWNER_ID,
  st.BILLING AS BILLING,
  Max(tr.GROUP_TEST_ID) AS GTEST_ID,
  Max(tr.SPECIMEN_TYPE) AS SPECIMEN_TYPE,
  Max(sp.DRAW_TYPE) AS DRAW_TYPE,
  Max(sp.NURSE_COLL) AS NURSE_COLL,
  Max(sp.COLLECTION_DT) AS COLL_DT,
  Max(sp.COLLECTION_PHLEB_ID) AS COL_TECH,
  Max(ord.COLLECT_DT) AS COLLECT_DT,
  Max(otst.CLINIC_ID) AS CLINIC_ID,
  Max(ord.ORDERING_CLINIC_ID) AS ORDERING_CLINIC_ID,
  Max(ord.ORDERING_TECH_ID) AS ORDERING_TECH_ID,
  Round((CASE
    WHEN Max(bbr.REVIEWDT) IS NOT NULL THEN (Max(bbr.REVIEWDT) -
      Max(tr.RECEIVE_DT))
    ELSE (Max(tr.VERIFIED_DT) - Max(tr.RECEIVE_DT))
  END) * 24 * 60, 0) AS MINUTES_VERIFIED_MINUS_RECEIVE,
  Round((Max(tr.RECEIVE_DT) - Max(tr.COLLECT_DT)) * 24 * 60,
  0) AS MINUTES_RECEIVE_MINUS_COLLECT,
  Max(bbr.REVIEWDT) AS REVIEWDT,
  cs.TOTAL_ORDERS,
  cs.TOTAL_COMPLIANT,
  cs.COMPLIANCE_PERCENTAGE,
  cs.TOTAL_COMPLIANT_730,
  cs.COMPLIANCE_PERCENTAGE_730,
  cs.TOTAL_COMPLIANT_900,
  cs.COMPLIANCE_PERCENTAGE_900
FROM V_P_LAB_MISCEL_INFO misc
  INNER JOIN V_P_LAB_STAY st ON st.BILLING = misc.OWNER_ID
  INNER JOIN V_P_LAB_PATIENT pt ON st.PATIENT_AA_ID = pt.AA_ID
  INNER JOIN V_P_LAB_ORDER ord ON ord.STAY_AA_ID = st.AA_ID
  INNER JOIN V_P_LAB_TEST_RESULT tr ON tr.ORDER_AA_ID = ord.AA_ID
  INNER JOIN V_P_LAB_ORDERED_TEST otst ON otst.ORDER_AA_ID = ord.AA_ID
  LEFT JOIN V_P_BB_Result bbr ON bbr.ORDERNO = otst.ORDER_NO
  INNER JOIN V_P_LAB_TUBE tb ON tb.ORDER_AA_ID = ord.AA_ID
  INNER JOIN V_P_LAB_SPECIMEN sp ON sp.AA_ID = tb.SPECIMEN_AA_ID AND tr.SPECIMEN_TYPE = tb.TUBE_TYPE
  CROSS JOIN compliance_summary cs
WHERE misc.VALUE IS NOT NULL AND misc.VALUE BETWEEN :Date1 AND :Date2 AND
  misc.SUB_ID = 'Exp Disch' AND
  ord.COLLECT_CENTER_ID = 'T1' AND sp.DRAW_TYPE = 'V' AND
  ord.ORDERING_TECH_ID LIKE 'HIS' AND ord.COLLECT_TIME = 0400 AND
  ord.COLLECT_DATE BETWEEN To_Date(:Date1, 'YYYYMMDD') AND To_Date(:Date2, 'YYYYMMDD') AND
  otst.ORDERING_DT BETWEEN To_Date(:Date1, 'YYYYMMDD') AND
  To_Date(Concat(:Date2, '2359'), 'YYYYMMDDHH24MI')
GROUP BY ord.STAY_AA_ID,
  Concat(Concat(pt.LAST_NAME, ','), pt.FIRST_NAME),
  misc.VALUE,
  misc.SUB_ID,
  CASE
    WHEN misc.VALUE IS NOT NULL THEN 1
    ELSE 0
  END,
  To_Char(misc.ADD_DT, 'YYYYMMDD'),
  misc.ADD_TECH,
  pt.ID,
  st.CLINIC_ID,
  st.ROOM,
  st.BED,
  ord.ID,
  ord.COLLECT_CENTER_ID,
  ord.ORDERED_DT,
  otst.COLLECTED_TECH,
  To_Char(ord.ORDERED_DT, 'YYYYMMDD'),
  To_Char(otst.ORDERING_DT, 'YYYYMMDD'),
  misc.OWNER_ID,
  st.BILLING,
  cs.TOTAL_ORDERS,
  cs.TOTAL_COMPLIANT,
  cs.COMPLIANCE_PERCENTAGE,
  cs.TOTAL_COMPLIANT_730,
  cs.COMPLIANCE_PERCENTAGE_730,
  cs.TOTAL_COMPLIANT_900,
  cs.COMPLIANCE_PERCENTAGE_900
ORDER BY EDD,
  ORD_ID