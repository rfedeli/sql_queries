/* Tacrolimus Monthly TAT Report — Temple Chemistry (TUHM)
   Measures: Received to Verified within 45 minutes
   Parameter: :start_date — month-end date (YYYYMMDD), e.g. '20260228'
              The query covers the full calendar month containing that date.
              Defaults to previous calendar month if left empty.
   Single query: detail rows with summary stats appended via window functions.
*/
SELECT
    TO_CHAR(tr.VERIFIED_DT, 'YYYY-MM')                             AS report_month,
    o.ID                                                             AS order_id,
    o.ORDERED_DT,
    tr.COLLECT_DT                                                    AS collected_dt,
    tr.RECEIVE_DT                                                    AS received_dt,
    tr.TEST_ID,
    tr.TEST_PERFORMING_LOCATION,
    tr.PRIORITY,
    DECODE(tr.PRIORITY, 'S','Stat', 'R','Routine', 'T','Timed', tr.PRIORITY) AS priority_desc,
    tr.VERIFIED_DT,
    ROUND((tr.VERIFIED_DT - tr.RECEIVE_DT) * 1440, 1)              AS tat_minutes,
    CASE
        WHEN (tr.VERIFIED_DT - tr.RECEIVE_DT) * 1440 <= 45
        THEN 'Y' ELSE 'N'
    END                                                              AS within_45,
    COUNT(*) OVER ()                                                 AS total_tests,
    SUM(CASE WHEN (tr.VERIFIED_DT - tr.RECEIVE_DT) * 1440 <= 45 THEN 1 ELSE 0 END) OVER ()
                                                                     AS within_45_count,
    COUNT(*) OVER () - SUM(CASE WHEN (tr.VERIFIED_DT - tr.RECEIVE_DT) * 1440 <= 45 THEN 1 ELSE 0 END) OVER ()
                                                                     AS over_45_count,
    ROUND(
        SUM(CASE WHEN (tr.VERIFIED_DT - tr.RECEIVE_DT) * 1440 <= 45 THEN 1 ELSE 0 END) OVER ()
        / COUNT(*) OVER () * 100, 1
    )                                                                AS pct_within_45,
    TO_CHAR(TRUNC(NVL(TO_DATE(:start_date, 'YYYYMMDD'), ADD_MONTHS(SYSDATE, -1)), 'MM'), 'Month YYYY') AS report_month_label
FROM
    V_P_LAB_TEST_RESULT tr
    JOIN V_P_LAB_ORDER  o ON o.AA_ID = tr.ORDER_AA_ID
WHERE
    tr.GROUP_TEST_ID             = 'TACR'
    AND tr.STATE                 IN ('Final', 'Verified', 'Corrected')
    AND tr.RECEIVE_DT            IS NOT NULL
    AND tr.VERIFIED_DT           IS NOT NULL
    AND tr.TEST_PERFORMING_LOCATION = 'TUH'
    AND tr.VERIFIED_DT           >= TRUNC(NVL(TO_DATE(:start_date, 'YYYYMMDD'), ADD_MONTHS(SYSDATE, -1)), 'MM')
    AND tr.VERIFIED_DT           <  ADD_MONTHS(TRUNC(NVL(TO_DATE(:start_date, 'YYYYMMDD'), ADD_MONTHS(SYSDATE, -1)), 'MM'), 1)
ORDER BY
    tr.VERIFIED_DT