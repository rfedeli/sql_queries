WITH base_q AS (
  SELECT pt.ID AS MRN,
      o.ID AS ORDNUM,
      To_Char(o.ORDERED_DT, 'YYYYMMDD HH24:MI') AS ORDDT,
      tr.GROUP_TEST_ID AS ORDTEST,
      tr.TEST_ID AS TEST_ID,
      otst.COLLECTION_CENTER_ID AS ORD_DEPOT,
      tr.TEST_PERFORMING_LOCATION AS PERF_LOC,
      tr.TEST_PERFORMING_DEPT AS PERF_DEPOT,
      Max(CASE WHEN loc.TYPE = 'O' THEN loc.ARRIVED_DT END) AS ARRIVED_FCC,
      Max(CASE WHEN loc.TYPE = 'C' THEN tr.COLLECT_DT  END) AS COLLECT_FCC,
      Max(CASE WHEN loc.TYPE = 'R' THEN sp.RECEIVE_DT  END) AS RR_FCC,
      Max(CASE WHEN loc.POSITION LIKE 'AOP-_>JNS' AND loc.TYPE = 'T'
               THEN loc.ARRIVED_DT END) AS LEFT_FCC,
      Max(CASE WHEN loc.TYPE = 'R' THEN loc.ARRIVED_DT END) AS ARRIVED_JNS,
      tr.VERIFIED_DT AS JNS_VERIFIED,
      tr.COLLECT_DT AS COLLECT_DT
    FROM V_P_LAB_PATIENT pt
      INNER JOIN V_P_LAB_STAY st ON st.PATIENT_AA_ID = pt.AA_ID
      INNER JOIN V_P_LAB_ORDER o ON o.STAY_AA_ID = st.AA_ID
      INNER JOIN V_P_LAB_ORDERED_TEST otst ON otst.ORDER_AA_ID = o.AA_ID
      INNER JOIN V_P_LAB_TEST_RESULT tr ON tr.ORDER_AA_ID = o.AA_ID AND
          otst.TEST_ID = tr.GROUP_TEST_ID AND otst.WORKSTATION_ID =
          tr.ORDERING_WORKSTATION_ID
      INNER JOIN V_P_LAB_TEST_TO_TUBE tt ON tt.RESULT_AA_ID = tr.AA_ID
      INNER JOIN V_P_LAB_TUBE tub ON tt.TUBE_AA_ID = tub.AA_ID
      INNER JOIN V_P_LAB_TUBE_LOCATION loc ON loc.TUBE_AA_ID = tub.AA_ID
          AND (loc.TYPE IN ('O','C','R')
               OR (loc.TYPE = 'T' AND loc.POSITION LIKE 'AOP-_>JNS'))
      INNER JOIN V_P_LAB_SPECIMEN sp ON tub.SPECIMEN_AA_ID = sp.AA_ID
    WHERE otst.COLLECTION_CENTER_ID = 'F2'
      AND tr.COLLECT_DT >= Trunc(SYSDATE - 1)
      AND tr.COLLECT_DT <  Trunc(SYSDATE)
      AND otst.CANCELLED_FLAG = 0
    GROUP BY pt.ID, o.ID, To_Char(o.ORDERED_DT, 'YYYYMMDD HH24:MI'),
             tr.GROUP_TEST_ID, tr.TEST_ID, otst.COLLECTION_CENTER_ID,
             tr.TEST_PERFORMING_LOCATION, tr.TEST_PERFORMING_DEPT,
             tr.VERIFIED_DT, tr.COLLECT_DT
    HAVING Max(CASE WHEN loc.POSITION LIKE 'AOP-_>JNS' AND loc.TYPE = 'T'
                    THEN loc.ARRIVED_DT END) IS NOT NULL
       AND Max(CASE WHEN loc.TYPE = 'R' THEN loc.ARRIVED_DT END) IS NULL
)
SELECT base_q.MRN,
  base_q.ORDNUM,
  base_q.ORDTEST,
  base_q.TEST_ID,
  base_q.ORD_DEPOT,
  base_q.PERF_LOC,
  base_q.PERF_DEPOT,
  To_Char(base_q.ARRIVED_FCC,  'YYYYMMDD HH24:MI') AS ARRIVED_FCC,
  To_Char(base_q.COLLECT_FCC,  'YYYYMMDD HH24:MI') AS COLLECT_FCC,
  To_Char(base_q.RR_FCC,       'YYYYMMDD HH24:MI') AS RR_FCC,
  To_Char(base_q.LEFT_FCC,     'YYYYMMDD HH24:MI') AS LEFT_FCC,
  To_Char(base_q.ARRIVED_JNS,  'YYYYMMDD HH24:MI') AS ARRIVED_JNS,
  To_Char(base_q.JNS_VERIFIED, 'YYYYMMDD HH24:MI') AS JNS_VERIFIED
FROM base_q
ORDER BY base_q.ORDNUM
