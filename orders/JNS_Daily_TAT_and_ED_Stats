-- Jeanes ED Daily TAT Stats (Stat priority only)
-- TAT intervals in minutes: Orderâ†’Collect, Collectâ†’Receive, Receiveâ†’Verify, Orderâ†’Verify
SELECT
  o.ID                    AS ORDNUM,
  o.ORDERING_CLINIC_ID    AS ORDWARD,
  tr.GROUP_TEST_ID        AS GTEST,
  tr.TEST_ID              AS TEST,
  'Stat'                  AS PRI1,
  MAX(o.ORDERED_DT)       AS ORDDT,
  MAX(spt.COLLECTION_DT)  AS COLL_DT,
  MAX(tr.RECEIVE_DT)      AS REC_DT,
  MAX(tr.VERIFIED_DT)     AS VERDT,
  MAX(ROUND((spt.COLLECTION_DT - o.ORDERED_DT) * 1440))  AS ORD_TO_COLL,
  MAX(ROUND((tr.RECEIVE_DT - spt.COLLECTION_DT) * 1440)) AS COLL_TO_REC,
  MAX(ROUND((tr.VERIFIED_DT - tr.RECEIVE_DT) * 1440))    AS REC_TO_VER,
  MAX(ROUND((tr.VERIFIED_DT - o.ORDERED_DT) * 1440))     AS ORD_TO_VER,
  CASE
    WHEN MAX(ROUND((tr.VERIFIED_DT - tr.RECEIVE_DT) * 1440)) > 45
      THEN '> 45 Minutes'
  END AS GRTH45,
  CASE
    WHEN tr.TEST_ID IN ('PTSEC', 'PTT', 'DDIM')
     AND MAX(ROUND((tr.VERIFIED_DT - tr.RECEIVE_DT) * 1440)) > 30
      THEN '> 30 Minutes'
    WHEN MAX(ROUND((tr.VERIFIED_DT - tr.RECEIVE_DT) * 1440)) > 45
      THEN '> 45 Minutes'
  END AS GRTH_30_45,
  st.EXTERNAL_VISIT_NUM,
  o.COLLECT_CENTER_ID,
  st.MRNNUM
FROM V_P_LAB_ORDER o
  INNER JOIN V_P_LAB_SPECIMEN_TUBE spt ON spt.ORDER_AA_ID = o.AA_ID
  INNER JOIN V_P_LAB_TEST_RESULT tr ON tr.ORDER_AA_ID = o.AA_ID
  INNER JOIN V_P_LAB_STAY st ON o.STAY_AA_ID = st.AA_ID
WHERE o.ORDERING_CLINIC_ID IN ('ER', 'JED', 'JEMR')
  AND o.PRIORITY = 'S'
  AND o.COLLECT_CENTER_ID = 'J1'
  AND tr.GROUP_TEST_ID IN ('BMP', 'CBCD', 'CBCC', 'CMP', 'TNIH', 'PT', 'PTT', 'DDIM')
  AND tr.TEST_ID IN ('HGB', 'K', 'TNIH', 'PTSEC', 'PTT', 'DDIM')
  AND spt.IS_CANCELLED = 'N'
  AND NOT EXISTS (
    SELECT 1 FROM V_P_LAB_TEST_RESULT_HISTORY trhist
    WHERE trhist.ATEST_AA_ID = tr.AA_ID
  )
  AND spt.COLLECTION_DT BETWEEN
    CASE
      WHEN :INI_DATE > 0 THEN TO_DATE(:INI_DATE, 'YYYYMMDD')
      ELSE TRUNC(SYSDATE) + :INI_DATE
    END
    AND
    CASE
      WHEN :END_DATE > 0 THEN TO_DATE(:END_DATE || ' 2359', 'YYYYMMDD HH24MI')
      ELSE TRUNC(SYSDATE) + :END_DATE + 0.999999
    END
GROUP BY o.ID, o.ORDERING_CLINIC_ID, tr.GROUP_TEST_ID, tr.TEST_ID,
         st.EXTERNAL_VISIT_NUM, o.COLLECT_CENTER_ID, st.MRNNUM
ORDER BY ORDNUM