SELECT DISTINCT
  pt.ID AS MRN,
  pt.LAST_NAME,
  pt.FIRST_NAME,
  pt.DOB_DT,
  pt.SEX,
  st.BILLING,
  st.CLINIC_ID,
  st.ROOM,
  st.BED,
  ord.ID AS ORDER_NUM,
  ord.ORDERED_DT,
  ord.ORDERING_CLINIC_ID AS WARD,
  ord.COLLECT_CENTER_ID AS DEPOT,
  ord.PRIORITY,
  tr.GROUP_TEST_ID AS TEST,
  tr.TEST_ID AS COMPONENT,
  tr.RESULT,
  tr.UNITS,
  tr.STATE,
  tr.COLLECT_DT,
  tr.RECEIVE_DT,
  tr.TEST_DT,
  tr.VERIFIED_DT,
  tr.TESTING_WORKSTATION_ID,
  tr.TEST_PERFORMING_DEPT,
  tr.TEST_PERFORMING_LOCATION,
  tr.SPECIMEN_TYPE
FROM V_P_LAB_PATIENT pt
  INNER JOIN V_P_LAB_STAY st ON st.PATIENT_AA_ID = pt.AA_ID
  INNER JOIN V_P_LAB_ORDER ord ON ord.STAY_AA_ID = st.AA_ID
  INNER JOIN V_P_LAB_TEST_RESULT tr ON tr.ORDER_AA_ID = ord.AA_ID
WHERE tr.TEST_ID = 'PTSEC'
  AND tr.RESULT <> '.'
  AND tr.STATE IN ('Final', 'Corrected')
  AND TRUNC(ord.ORDERED_DT) BETWEEN TO_DATE(TO_CHAR(:start_date), 'YYYYMMDD')
  AND TO_DATE(TO_CHAR(:end_date), 'YYYYMMDD')
ORDER BY ord.ORDERED_DT, pt.ID
